*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go vendor and cache
/vendor/
/bin/
/build/
/dist/
/tmp/
*.log

# Go modules (keep go.sum — needed for reproducibility)
# Uncomment the next line ONLY if you intentionally want to regenerate deps
# go.sum

# -------------------------------------------------------------
# Dependency / package managers
# -------------------------------------------------------------
node_modules/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
ENV/
*.egg-info/

# -------------------------------------------------------------
# Configuration and secrets
# -------------------------------------------------------------
*.env
.env.*
config.local.yaml
configs/*.local.yaml
configs/*.secret.yaml
credentials.json
secrets.json
.envrc

